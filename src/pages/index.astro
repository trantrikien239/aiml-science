---
import Layout from '../layouts/Layout.astro';

const requestAccessHref =
  'mailto:trantrikien239@gmail.com?subject=ml-agents%20early%20access%20request&body=' +
  encodeURIComponent(
    `Hi AILM,

I'd like early access to ml-agents.

Name:
Company / team:
Role:
What are you modeling? (use case)
Data scale (rows, number of tables):
`
  );
---

<Layout
  title="ml-agents — self-driving machine learning, audited | AILM"
  description="ml-agents turns a parquet file into a stakeholder-ready model. A supervised agent harness for Claude Code that runs an audited feature-engineering loop on your own machine."
>
  <header class="nav">
    <div class="container nav-inner">
      <a href="#top" class="brand">
        <svg viewBox="0 0 64 64" width="26" height="26" aria-hidden="true">
          <rect width="64" height="64" rx="14" fill="#0B0F14" stroke="rgba(148,163,184,.3)" />
          <path d="M12 46 L26 30 L36 38 L52 18" stroke="url(#lg)" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="52" cy="18" r="5" fill="#4ADE80" />
          <defs>
            <linearGradient id="lg" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0" stop-color="#22D3EE" />
              <stop offset="1" stop-color="#4ADE80" />
            </linearGradient>
          </defs>
        </svg>
        <span>AILM</span>
      </a>
      <nav class="nav-links">
        <a href="#how">How it works</a>
        <a href="#features">Features</a>
        <a href="#workflow">Workflow</a>
      </nav>
      <a href="#access" class="btn btn-primary nav-cta">Request access</a>
    </div>
  </header>

  <main id="top">
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-copy">
          <span class="eyebrow">ml-agents · private early access</span>
          <h1>
            Machine learning that runs itself.<br />
            <span class="grad">And audits itself.</span>
          </h1>
          <p class="hero-sub">
            ml-agents turns a parquet file into a stakeholder-ready model. Point it at your
            data, answer a short interview, and a supervised agent harness runs the
            feature-engineering loop on your own machine — sandboxed, audited, and reported.
            Built on Claude Code.
          </p>
          <div class="hero-ctas">
            <a href="#access" class="btn btn-primary">Request early access</a>
            <a href="#how" class="btn btn-ghost">See how it works</a>
          </div>
        </div>

        <div class="terminal" role="img" aria-label="Terminal session showing ml-agents commands running an auto-ML loop">
          <div class="terminal-bar">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="terminal-title">claude — your-project</span>
          </div>
          <pre class="terminal-body"><code><span class="t-prompt">&gt;</span> <span class="t-cmd">/ml-agents:init</span>
  <span class="t-ok">●</span> interview complete — binary classification · optimizing <span class="t-metric">gini</span>
  <span class="t-ok">●</span> automl.yaml written · project scaffolded · smoke test passed

<span class="t-prompt">&gt;</span> <span class="t-cmd">/ml-agents:start</span>
  <span class="t-dim">◆ inner agent launched in workspace/ (sandboxed)</span>
  exp_014  + rolling_30d_spend  <span class="t-ok">accepted</span>  <span class="t-up">▲ gini 0.412 → 0.428</span>
  exp_015  lgbm depth sweep     <span class="t-bad">rejected</span>  <span class="t-dim">reverted via git</span>
  <span class="t-audit">audit</span>  overfit <span class="t-ok">OK</span> · leakage <span class="t-ok">none</span> · memory <span class="t-ok">OK</span> → keep climbing

<span class="t-prompt">&gt;</span> <span class="t-cmd">/ml-agents:report</span>
  <span class="t-ok">●</span> report_model_external.md — stakeholder-ready model card</code></pre>
        </div>
      </div>

      <div class="container">
        <div class="statbar">
          <div class="stat"><strong>3</strong><span>task types</span></div>
          <div class="stat"><strong>11</strong><span>optimization metrics</span></div>
          <div class="stat"><strong>126</strong><span>automated tests</span></div>
          <div class="stat"><strong>100%</strong><span>on your hardware</span></div>
        </div>
      </div>
    </section>

    <!-- ============ HOW IT WORKS ============ -->
    <section id="how" class="section">
      <div class="container">
        <span class="eyebrow">How it works</span>
        <h2 class="section-title">Two agents. One climbs, one supervises.</h2>
        <p class="section-lead">
          Unsupervised automation is how AutoML overfits, leaks labels, and burns compute.
          ml-agents splits the work between two roles with an enforced boundary.
        </p>

        <div class="roles">
          <div class="role-card">
            <div class="role-tag supervisor">Outer supervisor</div>
            <h3>Watches everything. Trusts nothing.</h3>
            <p>
              Your main Claude Code session scaffolds the project, then audits on a loop —
              overfit gap, leakage smell, progress, liveness, memory — and decides when to
              stop. At the end, it writes the final report.
            </p>
          </div>
          <div class="role-divider" aria-hidden="true">
            <span>guardrail hooks enforce the boundary — no Docker required</span>
          </div>
          <div class="role-card">
            <div class="role-tag climber">Inner hill-climber</div>
            <h3>Experiments relentlessly. Inside a sandbox.</h3>
            <p>
              A background agent confined to its workspace edits
              <code>features.py</code>, <code>model.py</code> and <code>analysis.py</code>,
              runs experiments, journals every result, and reverts rejected experiments via
              git. It can't read or write anything outside its walls.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section id="features" class="section section-alt">
      <div class="container">
        <span class="eyebrow">Features</span>
        <h2 class="section-title">Everything a careful ML engineer would do. Automatically.</h2>

        <div class="feature-grid">
          <div class="feature">
            <h3>Guided interview</h3>
            <p>
              Infers your task from the target column, proposes time-based splits from a
              label-availability diagnostic, and flags leakage-prone columns — before a
              single experiment runs.
            </p>
          </div>
          <div class="feature">
            <h3>Supervised hill-climbing</h3>
            <p>
              The inner agent iterates features and models toward your metric. Every
              experiment is journaled; every rejected one is reverted via git. Nothing is
              lost, nothing lingers.
            </p>
          </div>
          <div class="feature">
            <h3>Continuous audits</h3>
            <p>
              Overfit gap, leakage smell, progress and health, liveness, memory pressure,
              and a principled stopping decision — checked on a loop, not after the damage
              is done.
            </p>
          </div>
          <div class="feature">
            <h3>Sandboxed by design</h3>
            <p>
              Hook-based guardrails confine the inner agent to its workspace — enforced by
              agent identity, so it can't escape by changing directories. No containers, no
              cluster, no infra.
            </p>
          </div>
          <div class="feature">
            <h3>Time-aware validation</h3>
            <p>
              Expanding-window splits with outer test windows that stay silent during
              development and are only inspected at report time. The test set can't leak
              into your iteration loop.
            </p>
          </div>
          <div class="feature">
            <h3>Two-tier reporting</h3>
            <p>
              An operator debug log for you, and a stakeholder model card for risk,
              compliance, and product — with real feature importance, SHAP, plots, and
              insights. Not placeholders.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ WORKFLOW ============ -->
    <section id="workflow" class="section">
      <div class="container">
        <span class="eyebrow">Workflow</span>
        <h2 class="section-title">Four commands from raw data to model card.</h2>

        <ol class="steps">
          <li class="step">
            <code class="step-cmd">/ml-agents:init</code>
            <p>
              Drop parquet files in <code>data/raw/</code> and answer a short interview.
              ml-agents infers the task, proposes splits, flags leakage risks, handles
              multi-table joins with diagnostics, scaffolds the project, and smoke-tests it.
            </p>
          </li>
          <li class="step">
            <code class="step-cmd">/ml-agents:start</code>
            <p>
              The inner agent starts climbing in the background while the supervisor enters
              its audit loop. Walk away — it's watched.
            </p>
          </li>
          <li class="step">
            <code class="step-cmd">/ml-agents:audit</code>
            <p>
              Check in any time: overfit gap, leakage smell, progress, liveness, memory,
              and whether it's time to stop.
            </p>
          </li>
          <li class="step">
            <code class="step-cmd">/ml-agents:report</code>
            <p>
              Generate the final report and a stakeholder-ready model card — the document
              you'd actually hand to risk, compliance, or product.
            </p>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============ TASKS & METRICS ============ -->
    <section class="section section-alt">
      <div class="container">
        <span class="eyebrow">Scope</span>
        <h2 class="section-title">Any tabular use case. The metric you actually care about.</h2>
        <p class="section-lead">
          A metric registry carries each metric's direction, so hill-climbing on
          <code>rmse</code> means going down — and the audit, reporting, and stopping logic
          all agree.
        </p>

        <div class="tasks">
          <div class="task-card">
            <h3>Binary classification</h3>
            <div class="chips">
              <span>gini</span><span>auc</span><span>log_loss</span><span>accuracy</span><span>f1</span>
            </div>
          </div>
          <div class="task-card">
            <h3>Regression</h3>
            <div class="chips">
              <span>rmse</span><span>mae</span><span>r2</span>
            </div>
          </div>
          <div class="task-card">
            <h3>Multiclass classification</h3>
            <div class="chips">
              <span>macro_f1</span><span>accuracy</span><span>log_loss</span>
            </div>
          </div>
        </div>

        <div class="specs">
          <div><strong>Engine</strong><span>Polars + LightGBM</span></div>
          <div><strong>Spec</strong><span>one <code>automl.yaml</code> drives everything</span></div>
          <div><strong>Escape hatches</strong><span>custom loaders &amp; splitters</span></div>
          <div><strong>Runs on</strong><span>macOS &amp; Linux, with Claude Code</span></div>
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section id="access" class="section cta">
      <div class="container cta-inner">
        <span class="eyebrow">Early access</span>
        <h2 class="section-title">ml-agents is in private early access.</h2>
        <p class="section-lead">
          We're onboarding a small group of data science teams. Tell us what you're
          modeling and we'll be in touch.
        </p>
        <a href={requestAccessHref} class="btn btn-primary btn-lg">Request early access</a>
        <p class="cta-note">
          Or write to <a href="mailto:trantrikien239@gmail.com">trantrikien239@gmail.com</a>
          with your use case.
        </p>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span>© 2026 AILM · ailm.science</span>
      <span>ml-agents — auto-ML agents for Claude Code</span>
    </div>
  </footer>
</Layout>

<style>
  /* ---- Nav ---- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(12px);
    background: rgba(10, 14, 20, 0.8);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 4rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    font-size: 1.05rem;
  }
  .nav-links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--text);
  }
  .nav-cta {
    padding: 0.5rem 1.1rem;
    font-size: 0.88rem;
  }
  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .nav-inner {
      justify-content: space-between;
    }
  }

  /* ---- Hero ---- */
  .hero {
    padding-block: 6rem 4rem;
    background:
      radial-gradient(60rem 30rem at 80% -10%, rgba(34, 211, 238, 0.09), transparent 60%),
      radial-gradient(50rem 28rem at 10% 0%, rgba(74, 222, 128, 0.07), transparent 60%);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: 3.5rem;
    align-items: center;
  }
  h1 {
    font-size: clamp(2.1rem, 4.6vw, 3.2rem);
    line-height: 1.12;
    letter-spacing: -0.025em;
    font-weight: 750;
  }
  .grad {
    background: var(--accent-grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-sub {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-top: 1.2rem;
    max-width: 54ch;
  }
  .hero-ctas {
    display: flex;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Terminal ---- */
  .terminal {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg-inset);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    font-size: 0.8rem;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.9rem;
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }
  .terminal-title {
    margin-left: 0.6rem;
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .terminal-body {
    padding: 1.1rem 1.2rem;
    overflow-x: auto;
    line-height: 1.75;
    color: var(--text-muted);
  }
  .t-prompt { color: var(--accent-a); font-weight: 700; }
  .t-cmd { color: var(--text); font-weight: 600; }
  .t-ok { color: var(--accent-b); }
  .t-bad { color: #f87171; }
  .t-up { color: var(--accent-b); }
  .t-dim { color: var(--text-faint); }
  .t-audit { color: var(--accent-a); font-weight: 600; }
  .t-metric { color: var(--accent-a); }

  /* ---- Stat bar ---- */
  .statbar {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
    overflow: hidden;
  }
  .stat {
    padding: 1.3rem 1rem;
    text-align: center;
    border-left: 1px solid var(--border);
  }
  .stat:first-child {
    border-left: none;
  }
  .stat strong {
    display: block;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    background: var(--accent-grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat span {
    color: var(--text-faint);
    font-size: 0.85rem;
  }
  @media (max-width: 720px) {
    .statbar {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat:nth-child(3) {
      border-left: none;
    }
    .stat:nth-child(n + 3) {
      border-top: 1px solid var(--border);
    }
  }

  /* ---- Roles (how it works) ---- */
  .roles {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
    align-items: stretch;
  }
  .role-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
    padding: 1.8rem;
  }
  .role-card h3 {
    margin: 0.9rem 0 0.6rem;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  .role-card p {
    color: var(--text-muted);
    font-size: 0.96rem;
  }
  .role-card code {
    font-size: 0.85em;
    color: var(--accent-a);
  }
  .role-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .role-tag.supervisor {
    color: var(--accent-a);
    background: rgba(34, 211, 238, 0.1);
    border: 1px solid rgba(34, 211, 238, 0.3);
  }
  .role-tag.climber {
    color: var(--accent-b);
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.3);
  }
  .role-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 10rem;
  }
  .role-divider span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-faint);
    text-align: center;
    line-height: 1.7;
    padding: 0.8rem;
    border-inline: 1px dashed var(--border-strong);
  }
  @media (max-width: 860px) {
    .roles {
      grid-template-columns: 1fr;
    }
    .role-divider {
      max-width: none;
    }
    .role-divider span {
      border-inline: none;
      border-block: 1px dashed var(--border-strong);
    }
  }

  /* ---- Sections ---- */
  .section-alt {
    background: linear-gradient(180deg, rgba(15, 21, 32, 0.6), rgba(15, 21, 32, 0.2));
    border-block: 1px solid var(--border);
  }

  /* ---- Features ---- */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin-top: 3rem;
  }
  .feature {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--bg);
    transition: border-color 0.15s ease;
  }
  .feature:hover {
    border-color: var(--border-strong);
  }
  .feature h3 {
    font-size: 1.02rem;
    margin-bottom: 0.55rem;
    letter-spacing: -0.01em;
  }
  .feature p {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 620px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Workflow steps ---- */
  .steps {
    list-style: none;
    padding: 0;
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    counter-reset: step;
  }
  .step {
    counter-increment: step;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
    padding: 1.5rem;
    position: relative;
  }
  .step::before {
    content: counter(step, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
    display: block;
    margin-bottom: 0.7rem;
  }
  .step-cmd {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--accent-b);
    background: rgba(74, 222, 128, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.22);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    margin-bottom: 0.8rem;
  }
  .step p {
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .step p code {
    font-size: 0.85em;
    color: var(--accent-a);
  }
  @media (max-width: 980px) {
    .steps {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 620px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Tasks & metrics ---- */
  .tasks {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin-top: 3rem;
  }
  .task-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    padding: 1.5rem;
  }
  .task-card h3 {
    font-size: 1rem;
    margin-bottom: 0.9rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .chips span {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    padding: 0.22rem 0.65rem;
  }
  @media (max-width: 860px) {
    .tasks {
      grid-template-columns: 1fr;
    }
  }
  .specs {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
  }
  .specs div {
    border-top: 2px solid var(--border-strong);
    padding-top: 0.8rem;
  }
  .specs strong {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin-bottom: 0.3rem;
  }
  .specs span {
    color: var(--text-muted);
    font-size: 0.92rem;
  }
  .specs code {
    font-size: 0.85em;
    color: var(--accent-a);
  }
  @media (max-width: 860px) {
    .specs {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ---- CTA ---- */
  .cta {
    background:
      radial-gradient(50rem 26rem at 50% 120%, rgba(74, 222, 128, 0.1), transparent 65%);
  }
  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .cta .section-lead {
    margin-inline: auto;
  }
  .btn-lg {
    margin-top: 2.2rem;
    padding: 0.9rem 1.9rem;
    font-size: 1.05rem;
