</style>

<script>
  // --- Hero terminal: looping typewriter replay ---
  const term = document.getElementById('term');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (term && !reduced) {
    const lines = [...term.children] as HTMLElement[];
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
    const typeCmd = async (line: HTMLElement) => {
      const cmd = line.querySelector('.t-cmd') as HTMLElement;
      const full = cmd.textContent ?? '';
      cmd.textContent = '';
      line.classList.add('visible', 'typing');
      for (const ch of full) {
        cmd.textContent += ch;
        await sleep(34);
      }
      line.classList.remove('typing');
      cmd.textContent = full;
    };
    (async () => {
      term.classList.add('js-anim');
      for (;;) {
        lines.forEach((l) => l.classList.remove('visible'));
        await sleep(700);
        for (const line of lines) {
          if (line.hasAttribute('data-cmd')) {
            await sleep(550);
            await typeCmd(line);
            await sleep(400);
          } else {
            line.classList.add('visible');
            await sleep(line.textContent?.trim() ? 380 : 120);
          }
        }
        await sleep(8000);
      }
    })();
  }

  // --- Early-access form: AJAX submit to Web3Forms ---
  const form = document.getElementById('access-form') as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector('.form-status') as HTMLElement;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
      const data = Object.fromEntries(new FormData(form));
      btn.disabled = true;
      status.className = 'form-status';
      status.textContent = 'Sending…';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!json.success) throw new Error(json.message);
        (form.querySelector('.form-grid') as HTMLElement).style.display = 'none';
        btn.style.display = 'none';
        status.classList.add('ok');
        status.textContent = "✓ Request received — we'll be in touch soon.";
      } catch {
        btn.disabled = false;
        status.classList.add('err');
        status.textContent =
          'Something went wrong — please email trantrikien239@gmail.com instead.';
      }
    });
  }
</script>
